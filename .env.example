# ── Telegram ───────────────────────────────────────────────────────────────────
# Get token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Your personal Telegram user ID (get from @userinfobot)
OWNER_ID=123456789

# Comma-separated Telegram user IDs allowed to use the bot (excluding owner)
# Leave empty if only owner should have access
WHITELIST_IDS=987654321,111222333

# ── Groq API ───────────────────────────────────────────────────────────────────
# Get 3 free API keys from https://console.groq.com
GROQ_API_KEY_1=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_2=gsk_yyyyyyyyyyyyyyyyyyyy
GROQ_API_KEY_3=gsk_zzzzzzzzzzzzzzzzzzzz

# Groq model (free tier supports these models)
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=2048
GROQ_TEMPERATURE=0.7

# ── Database (Neon PostgreSQL) ─────────────────────────────────────────────────
# Get connection string from https://neon.tech (free tier)
# Format: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Bot settings ───────────────────────────────────────────────────────────────
MAX_HISTORY_MESSAGES=20
MAX_MEMORY_ITEMS=50
BOT_NAME=Асылхан
BOT_SHORT_NAME=Асл

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
